# Destino do proxy de API — use estritamente NEXT_PUBLIC_API_URL
# O front chama /api/proxy/* e o Next encaminha para esta URL.
# Desenvolvimento local (backend Kotlin na máquina):
# NEXT_PUBLIC_API_URL=http://localhost:8080
# Produção (Vercel → Railway):
# NEXT_PUBLIC_API_URL=https://seu-app.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080
