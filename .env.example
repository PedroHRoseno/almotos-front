# URL base do back-end (usada no proxy via rewrites). Ex.: http://localhost:8080
# O front chama /api/proxy/* e o Next.js encaminha para aqui (evita CORS).
# Para desenvolvimento local com o backend Kotlin:
NEXT_PUBLIC_API_URL=http://localhost:8080
# Para produção:
# NEXT_PUBLIC_API_URL=https://tcc-voting-pedro.fun/api
